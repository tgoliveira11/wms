generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id
  externalId  String   @unique
  displayName String
  role        String
  createdAt   DateTime @default(now())
}
